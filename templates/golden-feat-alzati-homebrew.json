    "dae": {
      "macro": {
        "name": "Alzati",
        "img": "https://cdn-icons-png.flaticon.com/512/25/25637.png",
        "type": "script",
        "scope": "global",
        "command": "let actor = canvas.tokens.controlled[0]?.actor;\n\nif (!actor) {\n  ui.notifications.warn(\"Seleziona un token!\");\n  return;\n}\n\n// Cerca lo status \"Prone\" tra gli effetti attivi\nlet proneEffect = actor.effects.find(e => e.name === \"Prone\");\n\nif (proneEffect) {\n  // Rimuove l'effetto\n  await proneEffect.delete();\n  ui.notifications.info(\"Condizione 'Prone' rimossa.\");\n} else {\n  ui.notifications.info(\"Il token non è Prone.\");\n}",
        "author": "7Eyc9RLuLQ6brosi",
        "ownership": {
          "default": 3
        },
        "_id": null,
        "folder": null,
        "sort": 0,
        "flags": {},
